BattleFrontier_BattleFactoryLobby_Subscript_ChooseTier_Menu::
    msgbox BattleFrontier_BattleFactoryLobby_Text_ChooseTier_Menu, MSGBOX_DEFAULT
    multichoice 17, 0, MULTI_BATTLE_FACTORY_TIERS, FALSE

    compare VAR_RESULT, MULTI_B_PRESSED
    goto_if_eq BattleFrontier_BattleFactoryLobby_Subscript_ChooseTier_Menu_Default
    copyvar VAR_BATTLE_FACTORY_TIER, VAR_RESULT
    goto BattleFrontier_BattleFactoryLobby_Subscript_ChooseForms_Menu

BattleFrontier_BattleFactoryLobby_Subscript_ChooseTier_Menu_Default:
    setvar VAR_BATTLE_FACTORY_TIER, 0
    goto BattleFrontier_BattleFactoryLobby_Subscript_ChooseForms_Menu

BattleFrontier_BattleFactoryLobby_Subscript_ChooseForms_Menu:
    msgbox BattleFrontier_BattleFactoryLobby_Text_ChooseForms_Menu, MSGBOX_DEFAULT
    multichoice 17, 0, MULTI_BATTLE_FACTORY_FORMS, FALSE
    compare VAR_RESULT, MULTI_B_PRESSED
    goto_if_eq BattleFrontier_BattleFactoryLobby_Subscript_ChooseForms_Menu_Default
    compare VAR_RESULT, 0
    goto_if_eq BattleFrontier_BattleFactoryLobby_Subscript_ChooseForms_Menu_On
    setvar VAR_BATTLE_FACTORY_FORMS, 0
    return

BattleFrontier_BattleFactoryLobby_Subscript_ChooseForms_Menu_On:
    setvar VAR_BATTLE_FACTORY_FORMS, 1
    return

BattleFrontier_BattleFactoryLobby_Subscript_ChooseForms_Menu_Default:
    setvar VAR_BATTLE_FACTORY_FORMS, 1
    return

