	givemon SPECIES_BULBASAUR, 5
	goto_if_eq VAR_RESULT, MON_GIVEN_TO_PARTY, BattleFrontier_BattleFactoryLobby_EventScript_RechargeableRepelGiver_BulbasaurParty
